<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo17.controller.VehicleController"
            prefWidth="1100" prefHeight="700"
            stylesheets="/css/style.css">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 12 20;">
            <Button text="← Back to Dashboard" onAction="#goBack"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;"/>
            <Label text="🚗 Vehicle Management" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <ProgressIndicator fx:id="progressIndicator" prefWidth="25" prefHeight="25"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.55">

            <!-- LEFT: Vehicle Table with Search -->
            <VBox spacing="10" style="-fx-padding: 15;">
                <Label text="Vehicle Registry" style="-fx-text-fill: #2c3e50; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                <!-- Search Bar -->
                <HBox spacing="10">
                    <TextField fx:id="searchField" promptText="🔍 Search by registration..." HBox.hgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-border-color: #d5d8dc; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>
                    <Button text="Search" onAction="#handleSearch"
                            style="-fx-background-color: #4a7c59; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Clear" onAction="#handleClearSearch"
                            style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>

                <!-- Vehicle Table -->
                <TableView fx:id="vehicleTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colReg" text="Registration Number" prefWidth="140"/>
                        <TableColumn fx:id="colMake" text="Make" prefWidth="100"/>
                        <TableColumn fx:id="colModel" text="Model" prefWidth="100"/>
                        <TableColumn fx:id="colYear" text="Year" prefWidth="70"/>
                        <TableColumn fx:id="colColor" text="Color" prefWidth="80"/>
                        <TableColumn fx:id="colOwner" text="Owner" prefWidth="130"/>
                    </columns>
                </TableView>

                <!-- Pagination -->
                <Pagination fx:id="pagination" pageCount="1"/>

                <!-- Progress Indicators -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Load Progress:"/>
                    <ProgressBar fx:id="progressBar" prefWidth="200" prefHeight="8"/>
                    <Label fx:id="statusLabel" style="-fx-text-fill: #4a7c59; -fx-font-size: 11px;"/>
                </HBox>
            </VBox>

            <!-- RIGHT: Vehicle Form + Quick Reference -->
            <VBox spacing="12" style="-fx-padding: 15;">

                <!-- Add/Edit Form -->
                <Label text="Vehicle Details" style="-fx-text-fill: #2c3e50; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                <GridPane hgap="10" vgap="10">
                    <Label text="Registration *" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="regField" promptText="e.g., LSO-001-AA" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Make *" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="makeField" promptText="e.g., Toyota" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Model *" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="modelField" promptText="e.g., Hilux" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Year *" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="yearField" promptText="e.g., 2022" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Color" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <TextField fx:id="colorField" promptText="e.g., White" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Owner" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <ComboBox fx:id="ownerCombo" promptText="Select Owner" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                </GridPane>

                <HBox spacing="10">
                    <Button text="💾 Save" onAction="#handleSave" style="-fx-background-color: #4a7c59; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="🗑 Delete" onAction="#handleDelete" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="✕ Clear" onAction="#handleClear" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>

                <Separator/>

                <!-- Quick Reference (25 Records) -->
                <Label text="Quick Reference (25 Sample Records)" style="-fx-text-fill: #2c3e50; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <ScrollPane fitToWidth="true" prefHeight="160" style="-fx-background-color: white; -fx-border-color: #e5e8ea; -fx-border-radius: 8;">
                    <VBox fx:id="scrollContent" spacing="3" style="-fx-padding: 8;"/>
                </ScrollPane>

            </VBox>
        </SplitPane>
    </center>

    <bottom>
        <HBox spacing="10" style="-fx-background-color: white; -fx-border-color: #e5e8ea; -fx-border-width: 1 0 0 0; -fx-padding: 8 20;">
            <Label fx:id="formStatusLabel" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Vehicle Module" style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>
</BorderPane>