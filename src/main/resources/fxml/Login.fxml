<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.demo17.controller.LoginController"
      alignment="CENTER" spacing="16"
      style="-fx-background-color: #2c3e50;"
      prefWidth="500" prefHeight="400">

    <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

    <!-- Test Button with inline style -->
    <Button text="IF YOU SEE THIS GREEN BUTTON, STYLING WORKS!"
            style="-fx-background-color: #3d5a73; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 6;"/>

    <Separator/>

    <Label text="Username:" textFill="white"/>
    <TextField fx:id="usernameField" promptText="Enter username"
               style="-fx-background-color: white; -fx-border-color: #d5d8dc; -fx-border-radius: 6; -fx-padding: 8 12;"/>

    <Label text="Password:" textFill="white"/>
    <PasswordField fx:id="passwordField" promptText="Enter password"
                   style="-fx-background-color: white; -fx-border-color: #d5d8dc; -fx-border-radius: 6; -fx-padding: 8 12;"/>

    <Button fx:id="loginButton" text="LOGIN" onAction="#handleLogin"
            prefWidth="200"
            style="-fx-background-color: #4a7c59; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>

    <Label fx:id="statusLabel" textFill="#4a7c59"/>
    <ProgressIndicator fx:id="loadingIndicator" prefWidth="30" prefHeight="30"/>
    <Label text="Default credentials: admin / admin123" textFill="#95a5a6" style="-fx-font-size: 11px;"/>
</VBox>