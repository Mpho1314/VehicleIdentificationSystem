<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.demo17.controller.LoginController"
           styleClass="login-root">

    <VBox alignment="CENTER" styleClass="login-bg">

        <VBox alignment="CENTER" spacing="22" styleClass="login-card" maxWidth="480">

            <!-- HEADER -->
            <VBox alignment="CENTER" spacing="6">
                <Label text="🚗" style="-fx-font-size: 52px;"/>
                <Label text="Vehicle Identification System" styleClass="login-title"/>
                <Label text="Administrator Portal" styleClass="login-subtitle"/>
            </VBox>

            <Separator/>

            <!-- FORM -->
            <GridPane hgap="15" vgap="14" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints minWidth="90"/>
                    <ColumnConstraints minWidth="260"/>
                </columnConstraints>

                <Label text="Username" styleClass="login-field-label"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="usernameField"
                           promptText="Enter your username"
                           styleClass="login-field"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Password" styleClass="login-field-label"
                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               styleClass="login-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            </GridPane>

            <!-- BUTTON -->
            <Button fx:id="loginButton"
                    text="LOGIN"
                    onAction="#handleLogin"
                    prefWidth="220"
                    styleClass="login-button"/>

            <!-- FEEDBACK -->
            <ProgressIndicator fx:id="loadingIndicator"
                               prefWidth="32" prefHeight="32"
                               visible="false"/>

            <Label fx:id="statusLabel" styleClass="login-status" text=""/>

            <!-- HINT -->
            <VBox alignment="CENTER" spacing="3">
                <Label text="Default Credentials:"
                       style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                <Label text="Username: admin  |  Password: admin123"
                       styleClass="login-hint"/>
            </VBox>

        </VBox>
    </VBox>
</StackPane>