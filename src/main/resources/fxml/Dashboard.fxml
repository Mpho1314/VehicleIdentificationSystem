<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo17.controller.DashboardController"
            prefWidth="1000" prefHeight="680"

            styleClass="border-pane">

    <!-- TOP -->
    <top>
        <VBox>
            <MenuBar>
                <Menu text="File">
                    <MenuItem text="Exit" onAction="#menuExit"/>
                </Menu>
                <Menu text="Admin">
                    <MenuItem text="🔐 User Access Management" onAction="#menuAdmin"/>
                </Menu>
                <Menu text="Modules">
                    <MenuItem text="🚗 Vehicles" onAction="#menuVehicles"/>
                    <MenuItem text="👤 Customers" onAction="#menuCustomers"/>
                    <MenuItem text="🔧 Workshop" onAction="#menuWorkshop"/>
                    <MenuItem text="👮 Police" onAction="#menuPolice"/>
                </Menu>
                <Menu text="Demo">
                    <MenuItem text="📄 Pagination Demo (25 Records)" onAction="#menuPaginationDemo"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About" onAction="#menuAbout"/>
                </Menu>
            </MenuBar>

            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="top-bar">
                <Label text="🚗 Vehicle Identification System — Dashboard" styleClass="top-bar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="Search by registration…" prefWidth="220"/>
                <Button text="Search" onAction="#handleSearch" styleClass="button-outline"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER -->
    <center>
        <SplitPane dividerPositions="0.72">
            <VBox spacing="8" style="-fx-padding: 12 8 8 16;">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Vehicle Registry" styleClass="section-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="addVehicleButton" text="+ Add Vehicle" onAction="#handleAddVehicle" styleClass="success-button"/>
                    <Button fx:id="refreshButton" text="↻ Refresh" onAction="#handleRefresh" styleClass="secondary-button"/>
                </HBox>

                <TableView fx:id="vehicleTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colReg" text="Reg. No." prefWidth="130"/>
                        <TableColumn fx:id="colMake" text="Make" prefWidth="90"/>
                        <TableColumn fx:id="colModel" text="Model" prefWidth="100"/>
                        <TableColumn fx:id="colYear" text="Year" prefWidth="60"/>
                        <TableColumn fx:id="colColor" text="Color" prefWidth="80"/>
                        <TableColumn fx:id="colOwner" text="Owner" prefWidth="130"/>
                    </columns>
                </TableView>

                <Pagination fx:id="pagination" pageCount="1" maxPageIndicatorCount="5"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Data Progress:"/>
                    <ProgressBar fx:id="progressBar" prefWidth="220" prefHeight="16"/>
                    <ProgressIndicator fx:id="progressIndicator" prefWidth="24" prefHeight="24"/>
                </HBox>
            </VBox>

            <VBox spacing="6" style="-fx-padding: 12 16 8 8;">
                <Label text="Quick Reference List" styleClass="section-label"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                    <VBox fx:id="scrollContent" spacing="4" style="-fx-padding: 8; -fx-background-color: white;"/>
                </ScrollPane>
            </VBox>
        </SplitPane>
    </center>

    <!-- BOTTOM -->
    <bottom>
        <HBox spacing="12" styleClass="status-bar">
            <Label fx:id="statusLabel" text="Ready"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="VIS v1.0 — Limkokwing University" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>
</BorderPane>