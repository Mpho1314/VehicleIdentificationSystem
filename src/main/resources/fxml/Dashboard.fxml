<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo17.controller.DashboardController"
            styleClass="root-pane"
            stylesheets="/css/style.css"
            prefWidth="1000" prefHeight="700">

    <!-- TOP -->
    <top>
        <VBox>
            <MenuBar>
                <Menu text="Admin">
                    <MenuItem text="User Access Management" onAction="#menuAdmin"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About" onAction="#menuAbout"/>
                    <MenuItem text="Logout" onAction="#menuLogout"/>
                </Menu>
            </MenuBar>

            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="top-bar">
                <Label text="Vehicle Identification System" styleClass="top-bar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Dashboard" styleClass="top-bar-subtitle"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="0" styleClass="dashboard-root">

            <!-- Small welcome banner -->
            <VBox alignment="CENTER" spacing="8" styleClass="welcome-banner-small">
                <Label text="Welcome to VIS" styleClass="welcome-title-small"/>
                <Label text="Select a module below to get started" styleClass="welcome-subtitle-small"/>
            </VBox>

            <!-- Cards row - larger cards, no emojis -->
            <HBox spacing="30" alignment="CENTER" styleClass="cards-row-large">

                <!-- Vehicles - LARGER -->
                <VBox alignment="CENTER" spacing="15" styleClass="module-card-large" onMouseClicked="#menuVehicles">
                    <Label text="VEHICLES" styleClass="card-title-large"/>
                    <Separator styleClass="card-separator-large"/>
                    <Label text="Manage vehicle records and registry" styleClass="card-subtitle-large"/>
                    <Button text="Open Module" onAction="#menuVehicles" styleClass="card-button-large"/>
                </VBox>

                <!-- Customers - LARGER -->
                <VBox alignment="CENTER" spacing="15" styleClass="module-card-large" onMouseClicked="#menuCustomers">
                    <Label text="CUSTOMERS" styleClass="card-title-large"/>
                    <Separator styleClass="card-separator-large"/>
                    <Label text="View and manage vehicle owners" styleClass="card-subtitle-large"/>
                    <Button text="Open Module" onAction="#menuCustomers" styleClass="card-button-large"/>
                </VBox>

                <!-- Workshop - LARGER -->
                <VBox alignment="CENTER" spacing="15" styleClass="module-card-large" onMouseClicked="#menuWorkshop">
                    <Label text="WORKSHOP" styleClass="card-title-large"/>
                    <Separator styleClass="card-separator-large"/>
                    <Label text="Service records and maintenance" styleClass="card-subtitle-large"/>
                    <Button text="Open Module" onAction="#menuWorkshop" styleClass="card-button-large"/>
                </VBox>

                <!-- Police - LARGER -->
                <VBox alignment="CENTER" spacing="15" styleClass="module-card-large" onMouseClicked="#menuPolice">
                    <Label text="POLICE" styleClass="card-title-large"/>
                    <Separator styleClass="card-separator-large"/>
                    <Label text="Reports, violations and fines" styleClass="card-subtitle-large"/>
                    <Button text="Open Module" onAction="#menuPolice" styleClass="card-button-large"/>
                </VBox>

                <!-- Admin - LARGER -->
                <VBox alignment="CENTER" spacing="15" styleClass="module-card-admin-large" onMouseClicked="#menuAdmin">
                    <Label text="ADMIN" styleClass="card-title-admin-large"/>
                    <Separator styleClass="card-separator-admin-large"/>
                    <Label text="User access and permissions" styleClass="card-subtitle-admin-large"/>
                    <Button text="Open Module" onAction="#menuAdmin" styleClass="card-button-admin-large"/>
                </VBox>
            </HBox>

            <!-- Stats row -->
            <HBox spacing="0" alignment="CENTER" styleClass="stats-row-centered">
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS" styleClass="stat-box-left">
                    <Label text="Vehicle Registry" styleClass="stat-title"/>
                    <Label text="Track all registered vehicles in Lesotho" styleClass="stat-subtitle"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS" styleClass="stat-box-center">
                    <Label text="Police Integration" styleClass="stat-title"/>
                    <Label text="Instant access to violation records" styleClass="stat-subtitle"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS" styleClass="stat-box-right">
                    <Label text="Owner Management" styleClass="stat-title"/>
                    <Label text="Customer and ownership records" styleClass="stat-subtitle"/>
                </VBox>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

    <!-- BOTTOM -->
    <bottom>
        <HBox spacing="12" styleClass="status-bar">
            <Label text="System Ready" styleClass="status-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Vehicle Identification System | Limkokwing University | OOP II 2026" style="-fx-text-fill: #5a7a9e; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>