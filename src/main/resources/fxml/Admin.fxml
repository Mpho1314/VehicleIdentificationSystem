<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo17.controller.AdminController"
            prefWidth="1000" prefHeight="680">

    <top>
        <VBox>
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: #1b4332; -fx-padding: 14 20;">
                <Button text="Back to Dashboard" onAction="#goBack"
                        style="-fx-background-color: #40916c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Label text="Admin — User Access Management"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ProgressIndicator fx:id="progressIndicator" prefWidth="28" prefHeight="28"/>
            </HBox>

            <HBox style="-fx-background-color: #2d6a4f; -fx-padding: 8 20;">
                <Label fx:id="codeLabel"
                       text="Select a user to view their access code"
                       style="-fx-text-fill: #d8f3dc; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.63">

            <!-- LEFT: User Table -->
            <VBox spacing="10" style="-fx-padding: 16; -fx-background-color: #f8faf8;">
                <Label text="Registered System Users"
                       style="-fx-text-fill: #1b4332; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                <HBox spacing="16">
                    <Label text="GREEN = GRANTED"
                           style="-fx-text-fill: #2d6a4f; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label text="RED = DENIED"
                           style="-fx-text-fill: #c0392b; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label text="— Click a user to see their access code"
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px; -fx-font-style: italic;"/>
                </HBox>

                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId"       text="ID"          prefWidth="45"/>
                        <TableColumn fx:id="colUsername"  text="Username"    prefWidth="130"/>
                        <TableColumn fx:id="colCode"      text="Access Code" prefWidth="120"/>
                        <TableColumn fx:id="colRole"      text="Role"        prefWidth="100"/>
                        <TableColumn fx:id="colAccess"    text="Access"      prefWidth="90"/>
                        <TableColumn fx:id="colDate"      text="Created"     prefWidth="100"/>
                    </columns>
                </TableView>

                <ProgressBar fx:id="progressBar" prefWidth="100000" prefHeight="10"/>

                <HBox spacing="10">
                    <Button fx:id="grantButton" text="Grant Access"
                            onAction="#handleGrant"
                            style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button fx:id="denyButton" text="Deny Access"
                            onAction="#handleDeny"
                            style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Delete User"
                            onAction="#handleDelete"
                            style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- RIGHT: Create User Form -->
            <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: #f0f4f0;">
                <Label text="Create New User"
                       style="-fx-text-fill: #1b4332; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Separator/>

                <Label text="Username * (letters, numbers, underscore only)"
                       style="-fx-text-fill: #1b4332; -fx-font-weight: bold;"/>
                <TextField fx:id="usernameField"
                           promptText="e.g. workshop_user1"
                           style="-fx-border-color: #95d5b2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>

                <Label text="Password * (minimum 4 characters)"
                       style="-fx-text-fill: #1b4332; -fx-font-weight: bold;"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter password"
                               style="-fx-border-color: #95d5b2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>

                <Label text="Role / Module *"
                       style="-fx-text-fill: #1b4332; -fx-font-weight: bold;"/>
                <ComboBox fx:id="roleCombo" prefWidth="100000"
                          style="-fx-background-color: white; -fx-border-color: #95d5b2; -fx-border-radius: 6; -fx-background-radius: 6;"/>

                <Separator/>

                <VBox spacing="4"
                      style="-fx-background-color: #d8f3dc; -fx-padding: 12; -fx-background-radius: 8;">
                    <Label text="The system will auto-generate a unique Access Code."
                           style="-fx-text-fill: #1b4332; -fx-font-size: 12px;"/>
                    <Label text="Share the Access Code with the user so they can log in."
                           style="-fx-text-fill: #1b4332; -fx-font-size: 12px;"/>
                </VBox>

                <Button fx:id="addButton"
                        text="Create User and Generate Access Code"
                        onAction="#handleAddUser"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1b4332; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 0; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;"/>

                <Separator/>

                <Label text="Module Access Guide"
                       style="-fx-text-fill: #1b4332; -fx-font-size: 14px; -fx-font-weight: bold;"/>

                <VBox spacing="6"
                      style="-fx-background-color: white; -fx-padding: 14; -fx-background-radius: 8; -fx-border-color: #b7d4bf; -fx-border-radius: 8;">
                    <Label text="WORKSHOP  — Vehicle registration and service records"
                           style="-fx-text-fill: #2d6a4f; -fx-font-size: 12px;"/>
                    <Label text="CUSTOMER  — Vehicle condition and owner queries"
                           style="-fx-text-fill: #2d6a4f; -fx-font-size: 12px;"/>
                    <Label text="POLICE    — Vehicle reports and violations"
                           style="-fx-text-fill: #2d6a4f; -fx-font-size: 12px;"/>
                    <Label text="INSURANCE — Vehicle insurance tracking"
                           style="-fx-text-fill: #2d6a4f; -fx-font-size: 12px;"/>
                </VBox>
            </VBox>
        </SplitPane>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #1b4332; -fx-padding: 10 20;">
            <Label fx:id="statusLabel" text="Ready"
                   style="-fx-text-fill: #95d5b2; -fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Admin Module  |  VIS v1.0"
                   style="-fx-text-fill: #52796f; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>
</BorderPane>